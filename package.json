{
  "name": "agentme-cli",
  "version": "0.1.0",
  "description": "Build your portable AI identity with pure documents",
  "type": "module",
  "bin": {
    "agentme": "./dist/bin/agentme.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc && node scripts/copy-templates.mjs",
    "dev": "tsc --watch",
    "test": "tsx --test test/*.test.ts",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "identity",
    "agent",
    "profile",
    "cli",
    "persona",
    "knowledge-base",
    "cursor",
    "claude",
    "codex",
    "agents-md",
    "evolution",
    "archive",
    "cross-platform"
  ],
  "author": "AgentMe Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ChenShiyaung/AgentMe.git"
  },
  "homepage": "https://github.com/ChenShiyaung/AgentMe#readme",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md",
    "README.en.md"
  ],
  "dependencies": {
    "@inquirer/prompts": "^8.4.3",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
